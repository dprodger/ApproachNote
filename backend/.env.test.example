# Env vars for running the backend pytest suite against the local
# Dockerized test Postgres (see docker-compose.test.yml).
#
# Setup once:
#   cp backend/.env.test.example backend/.env.test
#
# Then before each test run:
#   source backend/.env.test
#   pytest backend/tests/
#
# Values here match docker-compose.test.yml. Change them only if you're
# running Postgres somewhere other than the default compose stack.

export DB_HOST=localhost
export DB_PORT=5432
export DB_NAME=jazz_test
export DB_USER=jazztest
export DB_PASSWORD=jazztest
export DB_SSLMODE=disable

export JWT_SECRET=pytest-test-secret
export RATELIMIT_ENABLED=false
